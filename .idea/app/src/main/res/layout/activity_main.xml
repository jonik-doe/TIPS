<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Расчёт чаевых"
        android:textSize="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.032" />

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Сумма счета -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Сумма счета" />

        <EditText
            android:id="@+id/etBillAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="Например, 123.45" />

        <!-- Процент чаевых -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Процент чаевых (5–30)" />

        <EditText
            android:id="@+id/etTipPercent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="По умолчанию 15%" />

        <!-- Количество человек -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Количество человек (1–20)" />

        <EditText
            android:id="@+id/etPeopleCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="По умолчанию 1" />

        <!-- Способ округления -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Способ округления чаевых" />

        <RadioGroup
            android:id="@+id/rgRounding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbFloor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Округление в меньшую сторону" />

            <RadioButton
                android:id="@+id/rbCeil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Округление в большую сторону" />

            <RadioButton
                android:id="@+id/rbNearest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Округление до ближайшего целого"
                android:checked="true" />
        </RadioGroup>

        <!-- Кнопка -->
        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Рассчитать" />

        <!-- Результаты -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Сумма чаевых:" />

        <TextView
            android:id="@+id/tvTipAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0,00" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Общая сумма:" />

        <TextView
            android:id="@+id/tvTotalAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0,00" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Сумма на человека:" />

        <TextView
            android:id="@+id/tvPerPersonAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0,00" />

        <!-- Поле для ошибок (опционально) -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/holo_red_dark"
            android:paddingTop="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>